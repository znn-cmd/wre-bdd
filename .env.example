# Google Sheet that stores all operational data (single spreadsheet ID)
GOOGLE_SHEETS_SPREADSHEET_ID=

# Option A: single-line JSON (e.g. Vercel env). Share the sheet with client_email as Editor.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option B: path to the downloaded .json key (typical for local dev):
GOOGLE_SERVICE_ACCOUNT_JSON_FILE=./wre-bd-6193e16a89ac.json

# Min 32 chars. Used to sign httpOnly session cookies after token exchange.
SESSION_JWT_SECRET=

# Public URL of the deployment (used in Telegram deep links). On Vercel you can leave empty — VERCEL_URL is used as fallback.
APP_BASE_URL=https://your-app.vercel.app

# Optional: default bot token if partner rows leave telegram_bot_token empty.
TELEGRAM_DEFAULT_BOT_TOKEN=

# Comma-separated transfer_status codes (Statuses sheet) that trigger Telegram to the partner.
# Default if unset: sent — use the same status_code as in your sheet (e.g. sent = "Sent to partner").
# TELEGRAM_NOTIFY_TRANSFER_STATUS_CODES=sent

# Weekly ops report (separate group): rolling 7-day stats from Audit_Log + current status breakdown.
# Chat id is often negative for groups/supergroups, e.g. -1005298063101 — confirm with @getidsbot.
# TELEGRAM_WEEKLY_REPORT_CHAT_ID=
# Optional: dedicated bot; otherwise TELEGRAM_DEFAULT_BOT_TOKEN is used.
# TELEGRAM_WEEKLY_BOT_TOKEN=

# Cron: Vercel вызывает route с User-Agent vercel-cron/* (отдельный CRON_SECRET в проекте не используется).

# Set to 1 only for CI/build without real secrets (pages that touch Sheets will not work).
# SKIP_ENV_VALIDATION=1
